FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_API_BASE_URL=http://localhost:8080
ENV VITE_AUTH_SERVICE_URL=$VITE_API_BASE_URL \
    VITE_USERS_SERVICE_URL=$VITE_API_BASE_URL \
    VITE_ACCOUNTS_SERVICE_URL=$VITE_API_BASE_URL \
    VITE_TRANSACTIONS_SERVICE_URL=$VITE_API_BASE_URL \
    VITE_AADHAR_SERVICE_URL=$VITE_API_BASE_URL \
    VITE_COMPANY_CRV_SERVICE_URL=$VITE_API_BASE_URL \
    VITE_NOTIFICATION_SERVICE_URL=$VITE_API_BASE_URL \
    VITE_PAYMENT_GATEWAY_URL=$VITE_API_BASE_URL
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx","-g","daemon off;"]